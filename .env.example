# 复制到 packages/cli/.env 后填入真实值。BMO 的 .env 会覆盖外层 shell 同名变量。
#
# 配置加载位置:
#   · 开发(CLI / 桌面 sidecar):packages/cli/.env —— 单一来源,sidecar 用绝对路径复用这份。
#   · 生产(打包后的桌面 App):~/.bmo/.env —— 打包环境没有仓库结构,且密钥不该进安装包,
#     所以分发前需让用户在此放一份同款配置(将来可由设置界面写入)。

# ── 对话 / Agent:Kimi(官方 OpenAI 兼容端点)──────────────────
# 走 Moonshot 官方 /v1（OpenAI 协议），agent loop 用 openai SDK。
BMO_CHAT_BASE_URL=https://api.moonshot.cn/v1
BMO_CHAT_API_KEY=sk-...
BMO_CHAT_MODEL=kimi-k2.6          # 用 bmo doctor 确认当前可用 model id
# BMO_CHAT_TEMPERATURE=0.3        # 默认 0.3(工具判断/引用要确定性);Moonshot 范围 [0,1]

# ── 截图 / 图片解析:Kimi vision(OpenAI 兼容多模态)────────────
# 纯文本 Kimi model 不一定支持图片。填入前先用 bmo doctor 验证。
# BMO_VISION_BASE_URL=https://api.moonshot.cn/v1
# BMO_VISION_API_KEY=sk-...
# BMO_VISION_MODEL=moonshot-v1-8k-vision-preview
# BMO_VISION_MAX_IMAGE_BYTES=8388608

# ── Embedding(任何 OpenAI 兼容端点均可)──────────────────────
# 默认:本地 Ollama bge-m3(免费 + 离线 + 中文友好,1024 维)
#   需先 ollama pull bge-m3 且 ollama serve 在跑
# 备选 阿里云 DashScope (Qwen):
#   EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   EMBEDDING_API_KEY=sk-...
#   EMBEDDING_MODEL=text-embedding-v3   (1024 维)
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024                # ⚠️ 必须与模型实际维度一致,换模型需同步改并重建向量

# ── 检索与切块参数(可选;可由桌面设置写入 ~/.bmo/.env)────────────
BMO_SIMILARITY_THRESHOLD=0.3
BMO_RECALL_K=20
BMO_RRF_K=60
BMO_CHUNK_MAX_CHARS=1000
BMO_CHUNK_OVERLAP=120

# ── 数据库位置(默认 ~/.bmo/bmo.db)────────────────────────────
# BMO_DB_PATH=/Users/you/.bmo/bmo.db
